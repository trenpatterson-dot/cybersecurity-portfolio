AMAZON_ASSOCIATE_TAG=yourtag-20
APP_ENV=development
LOG_LEVEL=INFO
DEBUG=false
DRY_RUN=true
PRODUCT_SOURCE_PROVIDER=mock

# Future Creators API scaffold.
# Signed request support is available. Configure the values below and set
# PRODUCT_SOURCE_PROVIDER=creators_api when you are ready to fetch real products.
CREATORS_API_PUBLIC_KEY=
CREATORS_API_PRIVATE_KEY=
CREATORS_API_HOST=
CREATORS_API_REGION=
CREATORS_API_MARKETPLACE=
CREATORS_API_SERVICE=execute-api
CREATORS_API_PATH=/creators-api/products
CREATORS_API_TARGET=
CREATORS_API_ITEM_IDS=

FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=
